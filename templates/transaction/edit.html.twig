{% extends 'base.html.twig' %}
{% block title %}Transactie Bewerken{% endblock %}

{% block body %}
    <style>
        /* Body achtergrond: bewegend radial gradient */
        body {
            background: radial-gradient(circle at top left, #a259ff, #3b0a83, #120027);
            background-size: 400% 400%;
            animation: gradientMove 10s ease infinite;
            color: white;
            font-family: 'Poppins', sans-serif;
            overflow-x: hidden;
        }

        @keyframes gradientMove {
            0% {background-position: 0% 50%;}
            50% {background-position: 100% 50%;}
            100% {background-position: 0% 50%;}
        }

        /* Kaart met formulier */
           .form-card {
               background: rgba(25, 5, 45, 0.95);
               border-radius: 25px;
               padding: 45px;
               max-width: 650px;
               margin: 70px auto;
               box-shadow: 0 0 35px rgba(162, 89, 255, 0.8), 0 0 10px rgba(255, 255, 255, 0.2) inset;
               border: 1px solid rgba(162, 89, 255, 0.5);
               transition: all 0.4s ease;
               position: relative;
               overflow: hidden;
           }

        /* Bewegend effect achter de kaart */
           .form-card::before {
               content: "";
               position: absolute;
               top: -50%;
               left: -50%;
               width: 200%;
               height: 200%;
               background: radial-gradient(circle, rgba(162,89,255,0.3), transparent 70%);
               animation: spin 10s linear infinite;
               z-index: 0;
           }

        @keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }

        /* Titel van het formulier */
           h2 {
               color: #fff;
               text-align: center;
               font-weight: 700;
               letter-spacing: 1px;
               text-shadow: 0 0 20px rgba(162, 89, 255, 1), 0 0 40px rgba(162, 89, 255, 0.6);
               margin-bottom: 35px;
               position: relative;
               z-index: 2;
           }

        /* Labels styling */
           label {
               color: #ffffff;
               font-weight: 500;
               text-shadow: 0 0 10px rgba(255, 255, 255, 0.8);
               position: relative;
               z-index: 2;
           }

        /* Input en select styling */
           .form-control, .form-select {
               background-color: rgba(45, 15, 71, 0.9);
               color: white;
               border: 1px solid rgba(255, 255, 255, 0.3);
               border-radius: 12px;
               padding: 12px 15px;
               box-shadow: inset 0 0 15px rgba(162, 89, 255, 0.4), 0 0 10px rgba(162, 89, 255, 0.3);
               transition: all 0.3s ease;
               z-index: 2;
               position: relative;
           }

        .form-control:focus, .form-select:focus {
            outline: none;
            border-color: #fff;
            box-shadow: 0 0 25px rgba(255, 255, 255, 0.9), 0 0 15px rgba(162, 89, 255, 1);
            background-color: rgba(80, 20, 130, 0.95);
        }

        /* Submit knop styling met animatie */
           button.btn {
               background: linear-gradient(90deg, #ff00ff, #a259ff, #00ffff);
               background-size: 300% 300%;
               animation: gradientShift 6s ease infinite;
               color: white;
               border: none;
               border-radius: 14px;
               padding: 14px 40px;
               font-size: 1.2rem;
               font-weight: 600;
               box-shadow: 0 0 25px rgba(162, 89, 255, 1), 0 0 10px rgba(255, 255, 255, 0.4);
               transition: all 0.3s ease;
               z-index: 2;
               position: relative;
           }

        @keyframes gradientShift {
            0% {background-position: 0% 50%;}
            50% {background-position: 100% 50%;}
            100% {background-position: 0% 50%;}
        }

        button.btn:hover {
            transform: scale(1.08);
            box-shadow: 0 0 40px rgba(255, 255, 255, 1), 0 0 60px rgba(162, 89, 255, 0.9);
        }

        /* Flashbericht voor succes */
           .alert-success {
               text-align: center;
               margin-bottom: 20px;
               border-radius: 10px;
               background: linear-gradient(90deg, #00c853, #009624);
               color: white;
               font-weight: 600;
               padding: 12px;
               box-shadow: 0 0 15px rgba(0, 255, 128, 0.6);
           }

        /* Terug link styling */
           .back-link {
               display: inline-block;
               margin-bottom: 20px;
               color: #a259ff;
               font-weight: 600;
               text-decoration: none;
               transition: 0.3s;
           }

        .back-link:hover {
            color: #fff;
            text-shadow: 0 0 10px rgba(162, 89, 255, 1);
        }
    </style>

    <div class="form-card">
        <!--  Terug naar transacties link -->
        <a href="{{ path('app_transaction') }}" class="back-link">← Terug naar Transacties</a>

        <h2>Transactie Bewerken</h2>

        <!--  Flash berichten tonen bij succes -->
        {% for message in app.flashes('success') %}
            <div class="alert-success">{{ message }}</div>
        {% endfor %}

        <!--  Start formulier -->
        {{ form_start(form) }}

        <!-- Bedrag invoer-->
        <div class="mb-3">
            {{ form_label(form.amount, 'Bedrag (€)') }}
            {{ form_widget(form.amount, {'attr': {'class': 'form-control'}}) }}
        </div>

        <!-- Datum invoer -->
        <div class="mb-3">
            {{ form_label(form.date, 'Datum') }}
            {{ form_widget(form.date, {'attr': {'class': 'form-control'}}) }}
        </div>

        <!-- Notitie invoer -->
        <div class="mb-3">
            {{ form_label(form.note, 'Notitie') }}
            {{ form_widget(form.note, {'attr': {'class': 'form-control', 'rows':'3'}}) }}
        </div>

        <!--  Type select (income / expense) -->
        <div class="mb-3">
            {{ form_label(form.type, 'Type (income/expense)') }}
            {{ form_widget(form.type, {'attr': {'class': 'form-select'}}) }}
        </div>

        <!-- Gebruiker select -->
        <div class="mb-3">
            {{ form_label(form.user, 'Gebruiker') }}
            {{ form_widget(form.user, {'attr': {'class': 'form-select'}}) }}
        </div>

        <!-- Categorie select -->
        <div class="mb-3">
            {{ form_label(form.category, 'Categorie') }}
            {{ form_widget(form.category, {'attr': {'class': 'form-select'}}) }}
        </div>

        <!--  Budget select -->
        <div class="mb-3">
            {{ form_label(form.budget, 'Budget') }}
            {{ form_widget(form.budget, {'attr': {'class': 'form-select'}}) }}
        </div>

        <!--  Submit knop -->
        <div class="text-end mt-3">
            <button class="btn btn-lg">💾 Bijwerken</button>
        </div>

        <!--  Einde formulier -->
        {{ form_end(form) }}
    </div>
{% endblock %}
