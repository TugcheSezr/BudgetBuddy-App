{% extends 'base.html.twig' %}

{% block title %}Transacties{% endblock %}

{% block stylesheets %}
    <style>
        /* Algemene stijlen voor de body */
        body {
            background-color: #0e0e12;
            color: #fff;
            font-family: 'Poppins', sans-serif;
        }

        /* Container voor de transacties */
        .transactions-container {
            background: linear-gradient(135deg, #4b1ba1, #8e2de2);
            padding: 40px;
            border-radius: 25px;
            box-shadow: 0 0 40px rgba(162, 89, 255, 0.6);
            margin-top: 40px;
            animation: fadeIn 1s ease-in-out;
        }

        /* Animatie voor fade-in effect */
        @keyframes fadeIn {
            from {opacity: 0; transform: translateY(10px);}
            to {opacity: 1; transform: translateY(0);}
        }

        /* Titel voor de pagina */
        h1 {
            color: #fff;
            font-weight: 700;
            text-align: center;
            text-shadow: 0 0 20px rgba(162, 89, 255, 0.9);
            margin-bottom: 30px;
        }

        /* Container voor de tabel (met een hover effect) */
        .table-container {
            background-color: #1c1c24;
            border-radius: 20px;
            padding: 25px;
            box-shadow: 0 0 30px rgba(162, 89, 255, 0.2);
            transition: 0.3s;
        }
        .table-container:hover {
            transform: scale(1.01);
            box-shadow: 0 0 40px rgba(162, 89, 255, 0.4);
        }

        /* Stijlen voor de 'Nieuwe Transactie' knop */
        .btn-add {
            background: linear-gradient(90deg, #a259ff, #7a00ff);
            border: none;
            border-radius: 10px;
            color: white;
            padding: 10px 25px;
            font-weight: 600;
            transition: all 0.3s ease;
            box-shadow: 0 0 15px rgba(162, 89, 255, 0.5);
        }
        .btn-add:hover {
            background: linear-gradient(90deg, #7a00ff, #a259ff);
            box-shadow: 0 0 25px rgba(162, 89, 255, 0.8);
            transform: scale(1.05);
        }

        /* Stijlen voor de bewerk- en verwijderknoppen */
        .btn-warning, .btn-danger {
            border: none;
            border-radius: 8px;
            font-weight: 600;
            padding: 6px 15px;
            transition: 0.3s;
        }
        .btn-warning {
            background: linear-gradient(90deg, #ffb300, #ff9100);
            color: #fff;
        }
        .btn-danger {
            background: linear-gradient(90deg, #ff1744, #d50000);
            color: #fff;
        }
        .btn-warning:hover, .btn-danger:hover {
            transform: scale(1.05);
            box-shadow: 0 0 15px rgba(255, 255, 255, 0.4);
        }

        /* Stijlen voor badges (Inkomen/Uitgave) */
        .badge {
            padding: 8px 12px;
            border-radius: 8px;
            font-weight: 600;
        }
        .badge.bg-success {
            background: linear-gradient(90deg, #00c853, #009624);
        }
        .badge.bg-danger {
            background: linear-gradient(90deg, #ff1744, #d50000);
        }

        /* Modal voor bevestigen van verwijdering */
        .modal-overlay {
            display: none; /* eerst verborgen */
            position: fixed;
            top: 0; left: 0;
            width: 100%; height: 100%;
            background: rgba(0,0,0,0.75);
            backdrop-filter: blur(8px);
            justify-content: center;
            align-items: center;
            z-index: 9999;
        }
        .modal-box {
            background: radial-gradient(circle at top left, #a259ff, #3b0a83, #120027);
            border: 2px solid rgba(162, 89, 255, 0.6);
            border-radius: 20px;
            box-shadow: 0 0 30px rgba(162, 89, 255, 0.7);
            padding: 40px;
            max-width: 400px;
            max-height: 80vh;
            overflow-y: auto;
            text-align: center;
            color: white;
        }
        .modal-box h3 {
            margin-bottom: 20px;
            font-weight: 700;
            text-shadow: 0 0 15px rgba(162, 89, 255, 1);
        }
        .modal-buttons {
            display: flex;
            justify-content: center;
            gap: 20px;
            margin-top: 20px;
        }
        .btn-confirm {
            background: linear-gradient(90deg, #ff1744, #d50000);
            border: none;
            padding: 10px 25px;
            border-radius: 10px;
            font-weight: 600;
            color: white;
            transition: 0.3s;
            box-shadow: 0 0 15px rgba(255, 23, 68, 0.6);
        }
        .btn-cancel {
            background: linear-gradient(90deg, #00c853, #009624);
            border: none;
            padding: 10px 25px;
            border-radius: 10px;
            font-weight: 600;
            color: white;
            transition: 0.3s;
            box-shadow: 0 0 15px rgba(0, 255, 128, 0.6);
        }
        .btn-confirm:hover, .btn-cancel:hover {
            transform: scale(1.05);
            box-shadow: 0 0 25px rgba(255,255,255,0.7);
        }
    </style>
{% endblock %}

{% block body %}
    <div class="container">
        <div class="transactions-container">
            <h1>💸 Transacties</h1>

            <!-- Flash-meldingen (bijv. succesberichten) -->
            {% for message in app.flashes('success') %}
                <div class="alert alert-success text-center fw-bold shadow-sm">{{ message }}</div>
            {% endfor %}

            <!-- Knop om een nieuwe transactie toe te voegen -->
            <div class="text-end mb-4">
                <a href="{{ path('transaction_new') }}" class="btn btn-add px-4 py-2">+ Nieuwe Transactie</a>
            </div>

            <!-- Tabelweergave van de transacties -->
            <div class="table-container">
                <table class="table table-dark table-hover align-middle text-center">
                    <thead>
                    <tr>
                        <th>Gebruiker</th>
                        <th>Categorie</th>
                        <th>Budget</th>
                        <th>Bedrag (€)</th>
                        <th>Type</th>
                        <th>Datum</th>
                        <th>Acties</th>
                    </tr>
                    </thead>
                    <tbody>
                    {% for transaction in transactions %}
                        <tr>
                            <td>{{ transaction.user.name }}</td> <!-- Naam van de gebruiker -->
                            <td>{{ transaction.category.name }}</td> <!-- Categorie van de transactie -->
                            <td>{{ transaction.budget.category.name }}</td> <!-- Budgetcategorie -->
                            <td class="fw-bold">{{ transaction.amount }}</td> <!-- Bedrag van de transactie -->
                            <td>
                                <!-- Type van de transactie (Inkomen of Uitgave) -->
                                {% if transaction.type == 'income' %}
                                    <span class="badge bg-success">Inkomen</span>
                                {% else %}
                                    <span class="badge bg-danger">Uitgave</span>
                                {% endif %}
                            </td>
                            <td>{{ transaction.date ? transaction.date|date('d-m-Y') : '—' }}</td> <!-- Datum van de transactie -->
                            <td>
                                <!-- Bewerken knop -->
                                <a href="{{ path('transaction_edit', {'id': transaction.id}) }}" class="btn btn-warning btn-sm">✏️ Bewerken</a>

                                <!-- Verwijderen knop met modal -->
                                <button class="btn btn-danger btn-sm" onclick="openModal({{ transaction.id }})">🗑️ Verwijderen</button>

                                <!-- Verborgen formulier voor het verwijderen van een transactie -->
                                <form id="delete-form-{{ transaction.id }}" action="{{ path('transaction_delete', {'id': transaction.id}) }}" method="post" style="display:none;">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ transaction.id) }}">
                                </form>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="7" class="text-muted">Geen transacties gevonden.</td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Modal voor bevestigen van transactie-verwijdering -->
    {% if transactions|length > 0 %}
        <div class="modal-overlay" id="deleteModal">
            <div class="modal-box">
                <h3>Weet je zeker dat je deze transactie wilt verwijderen?</h3>
                <div class="modal-buttons">
                    <button class="btn-confirm" id="confirmDelete">Ja, verwijderen</button>
                    <button class="btn-cancel" onclick="closeModal()">Annuleren</button>
                </div>
            </div>
        </div>
    {% endif %}

    <script>
        let currentTransactionId = null;

        // Open de modal voor verwijdering
        function openModal(id) {
            currentTransactionId = id;
            document.getElementById('deleteModal').style.display = 'flex';
        }

        // Sluit de modal
        function closeModal() {
            document.getElementById('deleteModal').style.display = 'none';
            currentTransactionId = null;
        }

        // Bevestig het verwijderen van een transactie
        document.getElementById('confirmDelete').addEventListener('click', function() {
            if (currentTransactionId) {
                document.getElementById('delete-form-' + currentTransactionId).submit();
            }
        });
    </script>
{% endblock %}
