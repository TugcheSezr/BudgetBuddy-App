{% extends 'base.html.twig' %}

{% block title %}User Profile{% endblock %}

{% block body %}
    <div class="profile-wrapper d-flex justify-content-center align-items-center vh-100">
        <!--  Hoofd container voor centreren van de profielkaart-->
        <div class="profile-card text-center p-5 rounded-4 shadow-lg">
            <!-- De kaart zelf met padding, afgeronde hoeken en schaduw-->

            <div class="profile-avatar mb-4 mx-auto">
                <!-- Avatar van de gebruiker (SVG icon hier) -->
                <svg xmlns="http://www.w3.org/2000/svg" width="96" height="96" fill="#0d6efd" class="bi bi-person-circle" viewBox="0 0 16 16">
                    <path d="M13.468 12.37C12.758 11.226 11.517 10.5 10 10.5s-2.758.726-3.468 1.87A6.987 6.987 0 0 1 2 8a7 7 0 1 1 14 0 6.987 6.987 0 0 1-2.532 4.37z"/>
                    <path fill-rule="evenodd" d="M8 9a3 3 0 1 0 0-6 3 3 0 0 0 0 6z"/>
                </svg>
            </div>

            <h1 class="mb-3 fw-bold text-gradient">Welcome, {{ user.name }}!</h1>
            <!--  Gebruikersnaam prominent weergegeven met gradient tekst -->

            <ul class="list-group list-group-flush mb-4 text-start">
                <!-- Lijst met gebruikersinformatie-->
                <li class="list-group-item d-flex align-items-center">
                    <!--  Eerste item: email -->
                    <i class="bi bi-envelope-fill me-3 text-primary fs-4"></i>
                    <div>
                        <div class="fw-semibold">Email</div>
                        <div class="text-muted">{{ user.email }}</div>
                    </div>
                </li>

                <li class="list-group-item d-flex align-items-center">
                    <!-- Tweede item: datum account creatie -->
                    <i class="bi bi-calendar-check-fill me-3 text-success fs-4"></i>
                    <div>
                        <div class="fw-semibold">Created At</div>
                        <div class="text-muted">{{ user.createdAt|date('F j, Y, g:i a') }}</div>
                    </div>
                </li>
            </ul>

            <a href="{{ path('dashboard') }}" class="btn btn-lg btn-gradient">Back to Dashboard</a>
            <!--  Knop om terug te gaan naar dashboard -->
        </div>
    </div>

    <style>
        /* Styling voor het profiel, gradient achtergrond, kaart animatie, puls effect op avatar */
        @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@400;600&display=swap');

        body {
            margin: 0;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            font-family: 'Poppins', sans-serif;
        }
        .profile-wrapper {
            background: rgba(255, 255, 255, 0.1);
            backdrop-filter: blur(15px);
            border-radius: 1.5rem;
            padding: 2rem;
        }
        .profile-card {
            background: white;
            max-width: 420px;
            width: 100%;
            border-radius: 1.5rem;
            box-shadow: 0 20px 40px rgba(0,0,0,0.2);
            animation: fadeInUp 0.8s ease forwards;
        }
        .profile-avatar svg {
            animation: pulse 2s infinite;
        }
        h1.text-gradient {
            background: linear-gradient(90deg, #667eea, #764ba2);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
        .list-group-item {
            border: none;
            padding: 1rem 0;
            border-bottom: 1px solid #eee;
            transition: background 0.3s ease;
            border-radius: 0.5rem;
        }
        .list-group-item:hover {
            background: #f9f9f9;
        }
        .btn-gradient {
            background: linear-gradient(90deg, #667eea, #764ba2);
            border: none;
            color: white;
            font-weight: 600;
            width: 100%;
            border-radius: 2rem;
            padding: 0.75rem 1rem;
            box-shadow: 0 8px 15px rgba(102, 126, 234, 0.4);
            transition: all 0.3s ease;
        }
        .btn-gradient:hover {
            background: linear-gradient(90deg, #5a67d8, #6b46c1);
            box-shadow: 0 12px 20px rgba(107, 70, 193, 0.6);
            transform: translateY(-3px);
        }

        /* Animaties */
        @keyframes pulse {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.1); }
        }
        @keyframes fadeInUp {
            0% { opacity: 0; transform: translateY(30px); }
            100% { opacity: 1; transform: translateY(0); }
        }
    </style>

    <!--  Bootstrap Icons toevoegen-->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">
{% endblock %}
