{% extends 'base.html.twig' %}

{% block title %}Join Budget Buddy{% endblock %}

{% block stylesheets %}
    <style>
        /* Body ve achtergrond */
        body {
            margin: 0;
            font-family: 'Poppins', sans-serif;
            background: radial-gradient(circle at 20% 20%, #250b4a, #0a0613 90%);
            color: #fff;
            overflow: hidden;
            height: 100vh;
        }

        /* Animated Background met blur en gradient layers */
        .animated-bg {
            position: fixed;
            top: 0; left: 0;
            width: 100%; height: 100%;
            z-index: 0;
            background: radial-gradient(circle at center, rgba(162,89,255,0.15) 0%, transparent 60%),
            radial-gradient(circle at 70% 30%, rgba(255,0,180,0.1) 0%, transparent 70%),
            radial-gradient(circle at 30% 70%, rgba(0,255,255,0.1) 0%, transparent 70%);
            background-size: 400% 400%;
            animation: bgMove 12s ease-in-out infinite alternate;
            filter: blur(100px);
        }

        @keyframes bgMove {
            0% {background-position: 0% 50%;}
            100% {background-position: 100% 50%;}
        }

        /* Floating particles (glowing orbs) */
        .particle {
            position: absolute;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(162,89,255,0.6), transparent 70%);
            filter: blur(8px);
            animation: floatParticle 10s infinite ease-in-out;
        }
        @keyframes floatParticle {
            0%, 100% {transform: translateY(0) scale(1);}
            50% {transform: translateY(-40px) scale(1.2);}
        }
        .p1 {width: 40px; height: 40px; top: 20%; left: 10%; animation-delay: 0s;}
        .p2 {width: 60px; height: 60px; bottom: 15%; right: 20%; animation-delay: 2s;}
        .p3 {width: 30px; height: 30px; top: 70%; left: 30%; animation-delay: 4s;}
        .p4 {width: 50px; height: 50px; top: 40%; right: 15%; animation-delay: 6s;}
        .p5 {width: 25px; height: 25px; bottom: 10%; left: 60%; animation-delay: 8s;}

        /* Register Card styling */
        .register-card {
            position: relative;
            z-index: 5;
            max-width: 480px;
            margin: 8% auto;
            background: rgba(25, 25, 40, 0.9);
            border: 1px solid rgba(162,89,255,0.3);
            border-radius: 25px;
            padding: 45px;
            box-shadow: 0 0 40px rgba(162, 89, 255, 0.2);
            backdrop-filter: blur(12px);
            animation: fadeIn 1.2s ease;
        }
        @keyframes fadeIn {
            from {opacity: 0; transform: translateY(20px);}
            to {opacity: 1; transform: translateY(0);}
        }

        h1 {
            text-align: center;
            color: #fff;
            font-weight: 700;
            margin-bottom: 30px;
            text-shadow: 0 0 25px rgba(162, 89, 255, 0.8);
        }

        label {
            color: #a259ff;
            font-weight: 600;
            font-size: 0.95rem;
        }

        .form-control {
            background-color: rgba(45, 45, 60, 0.8);
            border: none;
            border-radius: 12px;
            padding: 14px;
            color: #fff;
            transition: 0.3s;
        }

        .form-control:focus {
            outline: none;
            box-shadow: 0 0 18px rgba(162,89,255,0.7);
            transform: scale(1.02);
        }

        .btn-register {
            background: linear-gradient(90deg, #a259ff, #7a00ff);
            border: none;
            border-radius: 12px;
            color: white;
            padding: 14px 25px;
            font-weight: 600;
            width: 100%;
            margin-top: 15px;
            font-size: 1.1rem;
            letter-spacing: 0.5px;
            box-shadow: 0 0 20px rgba(162, 89, 255, 0.5);
            transition: all 0.3s ease;
        }
        .btn-register:hover {
            background: linear-gradient(90deg, #7a00ff, #a259ff);
            box-shadow: 0 0 35px rgba(162, 89, 255, 0.8);
            transform: translateY(-3px) scale(1.03);
        }

        .alert-success {
            background: rgba(162, 89, 255, 0.2);
            border: 1px solid rgba(162, 89, 255, 0.4);
            color: #d8caff;
            border-radius: 10px;
            padding: 12px;
            text-align: center;
            margin-bottom: 20px;
            font-weight: 500;
        }
    </style>
{% endblock %}

{% block body %}
    <div class="animated-bg"></div>
    <div class="particle p1"></div>
    <div class="particle p2"></div>
    <div class="particle p3"></div>
    <div class="particle p4"></div>
    <div class="particle p5"></div>

    <div class="register-card">
        <h1>🚀 Join Budget Buddy</h1>

        {% for message in app.flashes('success') %}
            <div class="alert alert-success">{{ message }}</div>
        {% endfor %}

        {{ form_start(form) }}
        <div class="mb-3">
            {{ form_label(form.name, 'Name') }}
            {{ form_widget(form.name, {'attr': {'class': 'form-control', 'placeholder': 'Your name'}}) }}
        </div>
        <div class="mb-3">
            {{ form_label(form.email, 'Email') }}
            {{ form_widget(form.email, {'attr': {'class': 'form-control', 'placeholder': 'Your email'}}) }}
        </div>
        <button type="submit" class="btn-register">Join Now</button>
        {{ form_end(form) }}
    </div>
{% endblock %}
