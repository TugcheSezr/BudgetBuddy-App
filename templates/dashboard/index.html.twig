{% extends 'base.html.twig' %}

{% block title %}Dashboard{% endblock %}

{% block stylesheets %}
    <style>
        /* --- Dashboard achtergrond --- */
        .dashboard-bg {
            background: linear-gradient(135deg, #4b1ba1, #811ba1);
            padding: 40px;
            border-radius: 20px;
            box-shadow: 0 0 30px rgba(131, 27, 161, 0.8);
            color: white;
            min-height: 85vh;
        }

        h1, h3 {
            color: #e5d7ff;
            font-weight: 900;
            text-shadow: 0 0 15px rgba(131, 27, 161, 0.9);
            letter-spacing: 1px;
        }

        /* --- Info kaarten --- */
        .info-card, .chart-container {
            background-color: #1c1c24;
            padding: 20px;
            border-radius: 15px;
            box-shadow: 0 0 20px rgba(0, 0, 0, 0.6);
            transition: all 0.3s ease;
            color: white;
            text-align: center;
        }

        .info-card:hover {
            transform: scale(1.05);
            box-shadow: 0 0 25px rgba(162, 89, 255, 0.9);
        }

        .chart-container { margin-top: 50px; padding: 30px; }

        /* --- Recent Expenses Kaarten --- */
        .expense-card {
            background-color: #1c1c24;
            padding: 20px;
            border-radius: 15px;
            box-shadow: 0 0 20px rgba(0, 0, 0, 0.6);
            margin-bottom: 20px;
            color: white;
            transition: all 0.3s ease;
        }

        .expense-card:hover {
            transform: scale(1.03);
            box-shadow: 0 0 25px rgba(162, 89, 255, 0.7);
        }

        /* --- See all button --- */
        .see-all-btn {
            display: block;
            text-align: center;
            margin-top: 20px;
            background-color: #a259ff;
            color: white;
            padding: 10px 20px;
            border-radius: 10px;
            text-decoration: none;
            font-weight: 600;
            transition: all 0.3s;
        }

        .see-all-btn:hover {
            background-color: #811ba1;
            text-decoration: none;
        }
    </style>
{% endblock %}

{% block body %}
    <div class="dashboard-bg" style="display:flex; gap:30px;">
        <!-- Main Content: Statistieken & Chart -->
        <div style="flex:1;">
            <h1 class="text-center mb-4">Dashboard</h1>

            <div style="display:flex; gap:20px; margin-top:30px;">
                <!-- Users info -->
                <div class="info-card" style="flex:1;">
                    <h3>Users</h3>
                    <p style="font-size:24px;">{{ users }}</p>
                </div>

                <!-- Categories info -->
                <div class="info-card" style="flex:1;">
                    <h3>Categories</h3>
                    <p style="font-size:24px;">{{ categories }}</p>
                </div>

                <!-- Transactions info -->
                <div class="info-card" style="flex:1;">
                    <h3>Transactions</h3>
                    <p style="font-size:24px;">{{ transactions }}</p>
                </div>

                <!-- Budgets info -->
                <div class="info-card" style="flex:1;">
                    <h3>Budgets</h3>
                    <p style="font-size:24px;">{{ budgets }}</p>
                </div>
            </div>

            <!-- Income vs Expense Chart -->
            <div class="chart-container">
                <h3>Income vs Expense</h3>
                <canvas id="chart" height="100"></canvas>
            </div>
        </div>

        <!-- Recent Expenses Sidebar -->
        <div style="flex:0.5;">
            <h1 class="text-center mb-4">Recent Expenses</h1>
            <div style="margin-top:30px;">
                {% for expense in recentExpenses %}
                    <div class="expense-card">
                        <h3>{{ expense.category.name }}</h3>
                        <p style="font-size:22px;">€ {{ expense.amount }}</p>
                        <p style="font-size:14px; color:#aaa;">{{ expense.date|date('d-m-Y') }}</p>
                        <p style="font-size:14px; color:#c1c1c1;">{{ expense.note }}</p>
                    </div>
                {% else %}
                    <p class="text-center text-muted">Geen uitgaven gevonden.</p>
                {% endfor %}
            </div>

            <a href="{{ path('app_transaction') }}" class="see-all-btn">
                See All Transactions
            </a>
        </div>
    </div>

    <!-- Chart.js Script -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const ctx = document.getElementById('chart').getContext('2d');
        new Chart(ctx, {
            type: 'bar',
            data: {
                labels: ['Income', 'Expense'],
                datasets: [{
                    data: [{{ income }}, {{ expense }}],
                    backgroundColor: ['#a259ff', '#ff5e78'],
                    borderRadius: 8,
                }]
            },
            options: {
                plugins: { legend: { display: false }},
                scales: {
                    x: { ticks: { color: 'white' }, grid: { display: false }},
                    y: { ticks: { color: 'white' }, grid: { color: 'rgba(255,255,255,0.1)' }}
                }
            }
        });
    </script>
{% endblock %}
